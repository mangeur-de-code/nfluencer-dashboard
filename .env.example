# Dashboard environment variables

# Admin API Base URL - points to the standalone admin microservice
# Production: https://api-admin.fanzzer.com or https://fanzzer-admin.dlouis20.workers.dev
# Development: http://localhost:8788 or deployed service
VITE_ADMIN_API_BASE_URL=https://fanzzer-admin.dlouis20.workers.dev

# Main app URL for navigation and authentication redirects
# Production: https://www.fanzzer.com
# Development: http://localhost:5173
VITE_MAIN_APP_URL=https://www.fanzzer.com

# Clerk authentication keys
# Get these from your Clerk dashboard
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_key_here

# Domain configuration for CORS and authentication
VITE_DOMAIN=fanzzer.com
# Copy to .env.local for local development

# Clerk publishable key (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Admin microservice base URL
# Development: http://localhost:8788 (wrangler dev for admin-service)
# Production:  https://api-admin.fanzzer.com
VITE_API_BASE_URL=http://localhost:8788

# Main app URL for navigation links
# Development: http://localhost:5173 (main app dev server)
# Production:  https://www.fanzzer.com
VITE_MAIN_APP_URL=http://localhost:5173

# Domain configuration
VITE_DOMAIN=fanzzer.com
