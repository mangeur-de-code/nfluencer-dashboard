# Dashboard environment variables
# Copy to .env.local for local development

# Clerk publishable key (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Admin microservice base URL
# Development: http://localhost:8788 (wrangler dev for admin-service)
# Production:  https://api-admin.nfluencer.co
VITE_ADMIN_API_BASE_URL=http://localhost:8788
